{
  "name": "delivery-eval-engine",
  "version": "1.0.0",
  "description": "数据标注需求交付评估计算工具",
  "main": "app/main/main.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build:engine": "tsc",
    "test": "jest tests/unit/engine tests/unit/services/validation.test.ts --forceExit",
    "test:all": "jest --forceExit",
    "test:coverage": "jest tests/unit/engine tests/unit/services/validation.test.ts --coverage --forceExit",
    "rebuild:electron": "electron-rebuild",
    "rebuild:node": "npm rebuild better-sqlite3",
    "dev": "electron-rebuild && electron app/main/main.js",
    "start": "electron app/main/main.js",
    "pack": "npm run build:engine && electron-builder --dir",
    "dist": "npm run build:engine && electron-builder",
    "dist:win": "npm run build:engine && electron-builder --win",
    "dist:mac": "npm run build:engine && electron-builder --mac"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "exceljs": "^4.4.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.0",
    "@types/uuid": "^10.0.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3"
  },
  "build": {
    "appId": "com.delivery-eval.tool",
    "productName": "数据标注交付评估工具",
    "directories": {
      "output": "release"
    },
    "files": [
      "app/**/*",
      "dist/**/*",
      "node_modules/**/*",
      "!node_modules/.cache"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "交付评估工具"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ]
  }
}
